# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Database
DATABASE_URL=postgresql://webhook:webhook@localhost:5432/webhook_catcher

# Auth
JWT_SECRET=change_me_in_production_use_a_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Admin (created on first boot if no users exist)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
